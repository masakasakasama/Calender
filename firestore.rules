rules_version = '2';

// =====================================================================
// calender アプリ用 Firestore ルール（シンプル版）。
// 許可した2人のメールなら、アプリのデータを全部読み書きできる。
// （項目ごとの細かい条件で書き込みが弾かれる事故を防ぐため、あえて単純化）
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // --- 既存 warikan-app 用（壊さないため残す） ---
    function isMember(spaceId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/spaces/$(spaceId))
        && request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.memberUids;
    }
    match /spaces/{spaceId} {
      allow read: if isMember(spaceId);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.memberUids;
      allow update: if isMember(spaceId) || request.auth.uid in request.resource.data.memberUids;
      allow delete: if false;
      match /{document=**} {
        allow read, write: if isMember(spaceId);
      }
    }

    // --- calender 用：許可した2人なら全部OK ---
    function isCalendarUser() {
      return request.auth != null
        && request.auth.token.email.lower() in [
          'masakasakasama.man@gmail.com',
          'rere.geier@gmail.com'
        ];
    }

    match /events/{id}                    { allow read, write: if isCalendarUser(); }
    match /share_links/{id}               { allow read, write: if isCalendarUser(); }
    match /rebecca_calendar_settings/{id} { allow read, write: if isCalendarUser(); }
    match /users/{id}                     { allow read, write: if isCalendarUser(); }
    match /app_config/{id}                { allow read, write: if isCalendarUser(); }
    match /app_versions/{id}              { allow read: if isCalendarUser(); allow write: if false; }
  }
}
