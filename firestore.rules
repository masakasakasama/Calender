rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Existing warikan-app rules. Keep these so the existing app does not break.
    function isMember(spaceId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/spaces/$(spaceId))
        && request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.memberUids;
    }

    match /spaces/{spaceId} {
      allow read: if isMember(spaceId);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.memberUids;
      allow update: if isMember(spaceId) || request.auth.uid in request.resource.data.memberUids;
      allow delete: if false;
      match /{document=**} {
        allow read, write: if isMember(spaceId);
      }
    }

    // Couple Calendar rules.
    function allowedCalendarEmails() {
      return [
        'masakasakasama.man@gmail.com',
        'rere.geier@gmail.com'
      ];
    }

    function rebeccaEmail() {
      return 'rere.geier@gmail.com';
    }

    function isCalendarAllowed() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in allowedCalendarEmails();
    }

    function isRebecca() {
      return isCalendarAllowed() && request.auth.token.email.lower() == rebeccaEmail();
    }

    match /events/{eventId} {
      allow read: if isCalendarAllowed()
        && resource.data.calendarType == 'shared'
        && resource.data.visibility == 'shared';
      allow create, update, delete: if isCalendarAllowed()
        && request.resource.data.calendarType == 'shared'
        && request.resource.data.visibility == 'shared';
    }

    match /share_links/{linkId} {
      allow read, write: if isRebecca();
    }

    match /rebecca_calendar_settings/{settingId} {
      allow read, write: if isRebecca();
    }

    match /users/{userId} {
      allow read, write: if isCalendarAllowed() && request.auth.uid == userId;
    }

    match /app_config/{document} {
      allow read, write: if isCalendarAllowed();
    }

    match /app_versions/{document} {
      allow read: if isCalendarAllowed();
      allow write: if false;
    }
  }
}
