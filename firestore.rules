rules_version = '2';

// Firestore rules for calender plus the existing warikan-app data.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Existing warikan-app rules. Keep these so the existing app does not break.
    function isMember(spaceId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/spaces/$(spaceId))
        && request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.memberUids;
    }

    match /spaces/{spaceId} {
      allow read: if isMember(spaceId);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.memberUids;
      allow update: if isMember(spaceId) || request.auth.uid in request.resource.data.memberUids;
      allow delete: if false;
      match /{document=**} {
        allow read, write: if isMember(spaceId);
      }
    }

    function isCalendarUser() {
      return request.auth != null
        && request.auth.token.email.lower() in [
          'masakasakasama.man@gmail.com',
          'rere.geier@gmail.com'
        ];
    }

    function isAnonymousCalendarSession() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    function isSharedEvent(data) {
      return data.calendarType == 'shared'
        && data.visibility == 'shared';
    }

    match /events/{id} {
      allow read: if isCalendarUser()
        || (isAnonymousCalendarSession() && isSharedEvent(resource.data));
      // 許可された2人はどの種類のイベント（plan_idea / rebecca_source 等）でも書ける。
      // 匿名セッションは共有イベントのみ作成/更新できる。
      allow create, update: if isCalendarUser()
        || (isAnonymousCalendarSession() && isSharedEvent(request.resource.data));
      allow delete: if false;
    }

    match /share_links/{id} {
      allow read, write: if isCalendarUser();
    }

    match /rebecca_calendar_settings/{id} {
      allow read, write: if isCalendarUser();
    }

    match /users/{id} {
      allow read, write: if isCalendarUser();
    }

    match /app_config/{id} {
      allow read, write: if isCalendarUser();
    }

    match /date_plan_feedback/{id} {
      allow read: if isCalendarUser();
      allow create, update: if isCalendarUser()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.preference in ['like', 'dislike'];
      allow delete: if false;
    }

    match /app_versions/{id} {
      allow read: if isCalendarUser();
      allow write: if false;
    }
  }
}
