rules_version = '2';

// =====================================================================
// Firestore セキュリティルール。
// 許可された2人のGoogleアカウントだけがアプリを利用できる。
// partner は共有予定のみ、rebecca は共有予定 + 自分のGoogle予定設定を扱う。
//
// 許可メールは下の allowedEmails に直接列挙する（app_config に依存せず、
// ルール単体で完結させて事故を防ぐ）。デプロイ時に実際の2人のメールへ置換すること。
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function allowedEmails() {
      return [
        'masakasakasama.man@gmail.com'
      ];
    }

    function rebeccaEmail() {
      return 'masakasakasama.man@gmail.com';
    }

    function isAllowed() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in allowedEmails();
    }

    function isRebecca() {
      return isAllowed() && request.auth.token.email.lower() == rebeccaEmail();
    }

    match /events/{eventId} {
      allow read: if isAllowed()
        && resource.data.calendarType == 'shared'
        && resource.data.visibility == 'shared';
      allow create, update, delete: if isAllowed()
        && request.resource.data.calendarType == 'shared'
        && request.resource.data.visibility == 'shared';
    }

    match /share_links/{linkId} {
      allow read, write: if isRebecca();
    }

    match /rebecca_calendar_settings/{settingId} {
      allow read, write: if isRebecca();
    }

    match /users/{userId} {
      allow read, write: if isAllowed() && request.auth.uid == userId;
    }

    match /app_config/{document} {
      allow read, write: if isAllowed();
    }

    match /app_versions/{document} {
      allow read: if isAllowed();
      allow write: if false;
    }
  }
}
