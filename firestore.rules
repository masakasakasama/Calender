rules_version = '2';

// =====================================================================
// Firestore セキュリティルール。
// 「彼氏/レベッカ」の役割区別は廃止。許可された2人のメールだけが
// 全データを読み書きできる。それ以外は一切アクセス不可。
//
// 許可メールは下の allowedEmails に直接列挙する（app_config に依存せず、
// ルール単体で完結させて事故を防ぐ）。デプロイ時に実際の2人のメールへ置換すること。
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function allowedEmails() {
      return [
        'me@example.com',       // ← 置換: ひとりめのGoogleアカウント
        'rebecca@example.com'   // ← 置換: レベッカのGoogleアカウント
      ];
    }

    function isAllowed() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in allowedEmails();
    }

    // すべてのアプリデータ（events / users / app_config /
    // rebecca_calendar_settings / share_links / app_versions）は
    // 許可された2人だけが読み書きできる。
    match /{document=**} {
      allow read, write: if isAllowed();
    }
  }
}
