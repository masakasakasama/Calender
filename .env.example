# =====================================================================
# Couple Calendar 環境変数サンプル
# 本番では実値を設定し、ビルド時に Vite が import.meta.env として注入する。
# MVP ではモック実装が使われるため、未設定でも動作する。
# =====================================================================

# --- 許可ユーザー（固定2名） -----------------------------------------
# Googleログインしたメールアドレスでロール判定する。
# partner: 共有カレンダーだけ使うアカウント
# rebecca: レベッカ本人。共有カレンダー + 自分のGoogleカレンダーを使うアカウント
VITE_PARTNER_EMAIL=partner@example.com
VITE_REBECCA_EMAIL=rebecca@example.com

# 固定カップルID（DBのドキュメントキーに使う想定）
VITE_FIXED_COUPLE_ID=couple-main

# --- バックエンド切り替えフラグ ---------------------------------------
# Firebase設定が揃っていれば自動でfirebase、未設定ならmock。
VITE_BACKEND=mock

# --- Firebase（本番で firebase を選んだ場合のみ必要） -----------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Google Calendar API（本番のみ） ----------------------------------
VITE_GOOGLE_CLIENT_ID=
# Firebase Auth の Google provider に以下を追加要求する。
VITE_GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar.readonly

# --- Web Push / FCM（本番のみ） ---------------------------------------
VITE_FCM_VAPID_KEY=
